# Chat-generation provider: 'gemini' (Google, fast) or 'ollama' (local).
# Embeddings + retrieval always stay on local Ollama, so switching this never
# requires re-ingesting the Chroma store.
AI_PROVIDER=ollama
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Ollama (local; no API key). Same server BOT + VIntuna use.
OLLAMA_BASE_URL=http://localhost:11434
RAG_EMBED_MODEL=nomic-embed-text
RAG_CHAT_MODEL=llama3.1:8b

# Retrieval / chunking (BOT defaults)
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_RETRIEVE_K=4

# Relevance floor for the support "only answer if we know" gate (0..1)
RAG_MIN_SCORE=0.35

RAG_COLLECTION=shakti
