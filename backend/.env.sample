PORT=8000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net
CORS_ORIGIN=http://localhost:3000

# User JWT
ACCESS_TOKEN_SECRET=your_access_token_secret_here
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRY=100d

# Admin JWT
ADMIN_ACCESS_TOKEN_SECRET=your_admin_access_token_secret_here
ADMIN_ACCESS_TOKEN_EXPIRY=1d
ADMIN_REFRESH_TOKEN_SECRET=your_admin_refresh_token_secret_here
ADMIN_REFRESH_TOKEN_EXPIRY=30d

# OTP temp token
TEMP_TOKEN_SECRET=your_temp_token_secret_here

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Resend (email)
RESEND_API=your_resend_api_key

# ── AI provider for Tempu Ai (agentic) + Tempu Rag (chat) ────────────────────
# 'gemini' = Google Gemini API (fast, cloud); 'ollama' = local model (private,
# slower). Flip anytime. Embeddings always stay on local Ollama.
AI_PROVIDER=ollama
# Needed only when AI_PROVIDER=gemini. Get a key at https://aistudio.google.com/apikey
# NOTE: the FREE tier may use your data for training — enable billing on the key's
# project for a no-training paid tier before sending real user data.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Knowledge Base / RAG (Ollama). Requires a local Ollama with the models pulled:
#   ollama pull nomic-embed-text   &&   ollama pull llama3.1:8b
OLLAMA_URL=http://localhost:11434
RAG_EMBED_MODEL=nomic-embed-text
RAG_CHAT_MODEL=llama3.1:8b
# Optional tuning (defaults shown)
# RAG_CHUNK_SIZE=1000
# RAG_CHUNK_OVERLAP=150
# RAG_RETRIEVE_K=4
# Support auto-reply: only answer when a KB chunk clears this cosine score,
# and cap how long the AI step may take before it's skipped for a human.
# RAG_MIN_SCORE=0.6
# RAG_SUPPORT_TIMEOUT_MS=25000

NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Python RAG microservice (rag-service/) — LangChain + Chroma + Ollama
RAG_SERVICE_URL=http://localhost:8100
RAG_MIN_SCORE=0.35
