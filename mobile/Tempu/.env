# Android emulator: use 10.0.2.2 (maps to your machine's localhost)
# Physical device: replace with your machine's local IP (e.g. 192.168.1.100)
# This laptop's LAN IP (run `hostname -I` to re-check if Wi-Fi reassigns it):
EXPO_PUBLIC_API_URL=http://192.168.0.124:8001/api/v1
# Old laptops / IPs:
# EXPO_PUBLIC_API_URL=http://192.168.110.9:8001/api/v1
# EXPO_PUBLIC_API_URL=http://192.168.200.202:8000/api/v1
# EXPO_PUBLIC_API_URL=http://192.168.136.132:5000/api/v1

# Native Google Maps SDK key for the MapView (screens/home/Map.js uses
# PROVIDER_GOOGLE). Without this the map renders as a blank white grid.
# Get one at console.cloud.google.com → enable "Maps SDK for Android"
# (and "Maps SDK for iOS" for iOS). Injected via app.config.js at build time.
# Re-run `npx expo prebuild --clean` after changing this.
GOOGLE_MAPS_API_KEY=