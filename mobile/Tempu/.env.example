# Backend API base URL.
# Android emulator: use http://10.0.2.2:<port>/api/v1
# Physical device: use your machine's LAN IP, e.g. http://192.168.1.100:8001/api/v1
EXPO_PUBLIC_API_URL=http://10.0.2.2:8001/api/v1

# Native Google Maps SDK key for the MapView (PROVIDER_GOOGLE on Android).
# Without it the map renders as a blank white grid.
# Enable "Maps SDK for Android" (and "Maps SDK for iOS") in Google Cloud Console.
# Read at build time by app.config.js; NOT prefixed EXPO_PUBLIC_ so it stays out
# of the JS bundle.
GOOGLE_MAPS_API_KEY=

# Optional TURN relay for WebRTC calls (STUN-only by default).
# EXPO_PUBLIC_TURN_URL=
# EXPO_PUBLIC_TURN_USERNAME=
# EXPO_PUBLIC_TURN_CREDENTIAL=
